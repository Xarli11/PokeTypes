---
import Layout from '../../layouts/Layout.astro';
import pokedex from '../../data/pokedex.json';

const { name: nameParam } = Astro.params;

// Find pokemon by slug/apiName on the server
const pokemon = pokedex.find(p => 
    (p.apiName || p.name).toLowerCase().replace(/\s+/g, '-') === nameParam
);

if (!pokemon) {
    return Astro.redirect('/404');
}

const { name, id } = pokemon;

const title = `${name} Weaknesses, Resistances & Type Chart | PokeTypes`;
const description = `Analyze weaknesses, resistances, and type effectiveness for ${name} (Gen 9, Scarlet & Violet). Detailed type calculator and defense breakdown for ${name}.`;
const imageUrl = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/${id}.png`;
---

<Layout title={title} description={description} image={imageUrl}>
    <div class="max-w-7xl mx-auto relative">
        <div class="absolute top-0 right-0 z-50 flex items-center gap-2">
            <button id="lang-toggle" class="p-2 rounded-lg bg-white dark:bg-slate-800 text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700 shadow-sm transition-all font-bold text-sm tracking-wide">
                ES
            </button>
            <button id="theme-toggle" class="p-2 rounded-lg bg-white dark:bg-slate-800 text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700 shadow-sm transition-all">
                <svg class="w-6 h-6 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                <svg class="w-6 h-6 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
            </button>
        </div>

        <header class="text-center mb-8">
            <a href="/" class="inline-flex items-center justify-center gap-3 mb-2 group">
                <svg class="w-9 h-9 md:w-12 md:h-12 text-slate-300 dark:text-slate-600 group-hover:text-slate-400 dark:group-hover:text-slate-500 flex-shrink-0 transition-colors" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle cx="50" cy="50" r="45" stroke="currentColor" stroke-width="7"/>
                    <path d="M5 50 H95" stroke="currentColor" stroke-width="7" stroke-linecap="round"/>
                    <circle cx="50" cy="50" r="17" stroke="currentColor" stroke-width="7"/>
                    <circle cx="50" cy="50" r="8" fill="currentColor"/>
                </svg>
                <h1 class="bento-title">Poketypes</h1>
            </a>
            <p class="text-slate-400 text-lg font-medium max-w-xl mx-auto">
                Analizando a <span class="text-indigo-500 font-bold">{name}</span>
            </p>
        </header>

        <div id="view-simple" class="grid grid-cols-1 md:grid-cols-12 gap-6">
            <section class="md:col-span-12 bento-card dark:bg-slate-800 dark:border-slate-700 flex flex-col lg:flex-row items-center gap-6">
                <div class="relative w-full lg:flex-1">
                    <input id="pokemon-search" type="text" placeholder="Search Pokemon..." class="search-input dark:bg-slate-900 dark:text-white dark:border-slate-700 dark:placeholder-slate-500">
                    <ul id="suggestions" class="hidden dark:bg-slate-800 dark:border-slate-700"></ul>
                </div>
                <div class="flex flex-col sm:flex-row items-center gap-4 w-full lg:w-auto">
                    <div class="relative w-full sm:w-48">
                        <select id="type-select" class="bento-select dark:bg-slate-900 dark:text-white dark:border-slate-700">
                            <option value="">Type 1</option>
                        </select>
                    </div>
                    <div class="relative w-full sm:w-48">
                        <select id="type2-select" class="bento-select dark:bg-slate-900 dark:text-white dark:border-slate-700">
                            <option value="">Type 2</option>
                        </select>
                    </div>
                    <div class="relative w-full sm:w-48 group">
                        <select id="type3-select" class="bento-select dark:bg-slate-900 dark:text-white dark:border-slate-700">
                            <option value="" data-i18n="type_3">Extra Type</option>
                        </select>
                        <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-48 bg-slate-800 text-white text-xs p-2 rounded-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 text-center pointer-events-none shadow-xl" data-i18n="type3_tooltip">Simulates effects like Forest's Curse or Trick-or-Treat that add a 3rd typing.</div>
                    </div>
                    <button id="reset-button" class="w-full sm:w-auto px-8 py-4 rounded-2xl bg-slate-900 text-white font-bold hover:bg-indigo-600 transition-colors duration-200 dark:bg-indigo-600 dark:hover:bg-indigo-500">
                        Reset
                    </button>
                </div>
            </section>

            <section id="pokemon-stats" class="md:col-span-12 grid grid-cols-1 lg:grid-cols-12 gap-6">
                <div id="pokemon-hero" class="lg:col-span-3 bento-card dark:bg-slate-800 dark:border-slate-700 flex flex-col items-center justify-center relative overflow-hidden min-h-[300px]">
                    <img src={`https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/${id}.png`} alt={name} class="w-48 h-48 object-contain drop-shadow-xl" />
                    <h2 class="text-2xl font-black mt-4 dark:text-white">{name}</h2>
                </div>
                <div class="lg:col-span-4 bento-card dark:bg-slate-800 dark:border-slate-700 flex flex-col justify-center">
                    <div id="stats-container" class="space-y-4">
                        <div class="text-center p-4 text-slate-400 italic">Cargando estadísticas...</div>
                    </div>
                </div>
                <div class="lg:col-span-5 bento-card dark:bg-slate-800 dark:border-slate-700 flex flex-col justify-center">
                    <div id="abilities-container" class="grid grid-cols-1 gap-4"></div>
                </div>
            </section>

            <section id="competitive-section" class="md:col-span-12 bento-card dark:bg-slate-800 dark:border-slate-700 hidden">
                <div id="competitive-container"></div>
            </section>

            <section id="type-details" class="md:col-span-12 grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="md:col-span-2 bento-card dark:bg-slate-800 dark:border-slate-700 !py-6 !px-10 flex flex-wrap items-center justify-between gap-4">
                    <h2 class="text-xl font-bold text-slate-400 uppercase tracking-widest">Análisis Activo</h2>
                    <div id="selected-type-name" class="flex items-center gap-2"></div>
                </div>
                <div class="flex flex-col gap-6">
                    <div class="bento-card dark:bg-slate-800 dark:border-slate-700">
                        <div id="weaknesses" class="effectiveness-card dark:border-slate-700"></div>
                        <div id="neutral-damage" class="effectiveness-card border-t border-gray-50 pt-6 dark:border-slate-700"></div>
                        <div id="resistances" class="effectiveness-card border-t border-gray-50 pt-6 dark:border-slate-700"></div>
                        <div id="immunities" class="effectiveness-card border-t border-gray-50 pt-6 dark:border-slate-700"></div>
                    </div>
                </div>
                <div class="bento-card dark:bg-slate-800 dark:border-slate-700">
                    <div id="super-effective" class="effectiveness-card dark:border-slate-700"></div>
                    <div id="neutral-offense" class="effectiveness-card border-t border-gray-50 pt-6 dark:border-slate-700"></div>
                    <div id="not-very-effective" class="effectiveness-card border-t border-gray-50 pt-6 dark:border-slate-700"></div>
                    <div id="no-effect" class="effectiveness-card border-t border-gray-50 pt-6 dark:border-slate-700"></div>
                </div>
            </section>
        </div>
    </div>
    <script src="../../js/main.js"></script>
</Layout>
